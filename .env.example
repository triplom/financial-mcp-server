# ── Required API Keys ──────────────────────────────────────────────────────────
# FRED (Federal Reserve Economic Data) – free key from https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# ── Optional API Keys (server works without these, but degrades gracefully) ────

# Alpha Vantage – free key from https://www.alphavantage.co/support/#api-key
# WARNING: Free tier is 25 requests/day as of 2024. Cache aggressively.
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Tiingo – free key from https://www.tiingo.com/account/api/token
# Free tier: 50 req/hr, 1000 tickers/month. Best for validated historical data + news.
TIINGO_API_KEY=your_tiingo_key_here

# Polygon.io – free key from https://polygon.io/
# Free tier: 5 req/min REST, unlimited WebSocket for crypto.
POLYGON_API_KEY=your_polygon_key_here

# CoinGecko Demo API – free key from https://www.coingecko.com/en/api
# Demo tier: 30 req/min. Without key, falls back to public API (10–30 req/min, less stable).
COINGECKO_API_KEY=your_coingecko_demo_key_here

# ── Cache Configuration ────────────────────────────────────────────────────────
# All TTL values are in seconds
CACHE_TTL_QUOTES=60
CACHE_TTL_EOD_PRICES=86400
CACHE_TTL_FUNDAMENTALS=86400
CACHE_TTL_FRED=86400
CACHE_TTL_SEC_FILINGS=604800
CACHE_TTL_NEWS=900
CACHE_TTL_CRYPTO=120

# ── Server Configuration ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
